# GoHighLevel API Configuration
GHL_API_KEY=your_private_integration_api_key_here
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_LOCATION_ID=your_location_id_here

# Server Configuration
MCP_SERVER_PORT=8000
NODE_ENV=development

# Router Mode: true (default) exposes ~16 category meta-tools instead of 550+
# Set to false for classic mode with all individual tools
MCP_ROUTER_MODE=true

# Optional: For AI features
OPENAI_API_KEY=your_openai_key_here_optional
